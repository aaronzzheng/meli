<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/meli_surface"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="12dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/meli_line_soft" />

    <TextView
        android:id="@+id/commentsSheetTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="@color/meli_ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/commentsReplyingToText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/meli_text_muted"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/commentsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/commentsInputEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_comment_input_rect"
        android:gravity="top|start"
        android:hint="Add a comment"
        android:minHeight="72dp"
        android:padding="12dp"
        android:textColor="@color/meli_ink"
        android:textColorHint="@color/meli_text_muted" />

    <TextView
        android:id="@+id/commentsPostButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:text="Post"
        android:textColor="@color/meli_ink"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
