<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/meli_card_spacing"
    android:background="@drawable/bg_profile_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_profile_avatar">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/person_24dp_000000_fill0_wght400_grad0_opsz24"
            android:tint="@android:color/black" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notificationMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Julie wants to add you as a friend!"
            android:textAppearance="@style/TextAppearance.Meli.SectionTitle"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/notificationTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="2d"
            android:textColor="@color/meli_text_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/notificationStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/meli_text_muted"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notificationAcceptButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notification_accept_circle"
            android:gravity="center"
            android:text="✓"
            android:textColor="#2F7E69"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/notificationDeclineButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_notification_decline_circle"
            android:gravity="center"
            android:text="X"
            android:textColor="#B23A32"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
