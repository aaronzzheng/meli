<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/commentAvatarImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Commenter avatar"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_profile_black_24dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceMeliCircle" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/commentActorNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/meli_ink"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/commentReplyToText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/meli_text_muted"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/commentBodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/meli_ink"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/commentReplyButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="Reply"
                android:textColor="@color/meli_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/commentLikeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_feed_heart_outline"
                android:drawablePadding="6dp"
                android:text="0"
                android:textColor="@color/meli_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
