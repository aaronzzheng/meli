<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/meli_paper"
    tools:context=".ui.profile.ProfileFragment">

    <LinearLayout
        android:id="@+id/profileTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/meli_screen_padding"
        android:layout_marginTop="@dimen/meli_screen_padding"
        android:layout_marginEnd="@dimen/meli_screen_padding"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/profileNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Name"
                android:textAppearance="@style/TextAppearance.Meli.ScreenTitle" />

            <ImageButton
                android:id="@+id/profileMenuButton"
                style="@style/Widget.Meli.IconButton"
                android:contentDescription="@string/cd_open_settings"
                android:src="@drawable/menu_24dp_000000_fill0_wght400_grad0_opsz24" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileAvatarImage"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:background="#FAFAFA"
                android:contentDescription="Profile picture"
                android:padding="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_black_24dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceMeliCircle"
                app:strokeColor="@android:color/black"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/profileUsernameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@username"
                android:textColor="@android:color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileFriendCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:text="1 friends"
                android:textColor="@android:color/black"
                android:textSize="26sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/profileAddFriendButton"
                style="@style/Widget.Meli.OutlinedActionButton"
                android:layout_width="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Add Friend"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
        android:id="@+id/profileActivityHeaderText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Your Activity"
        android:textAppearance="@style/TextAppearance.Meli.SectionTitle" />

        <View
            android:id="@+id/profileActivityDivider"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/meli_line" />
    </LinearLayout>

    <TextView
        android:id="@+id/profileActivityEmptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/meli_screen_padding"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="@dimen/meli_screen_padding"
        android:text="No ranking activity yet."
        android:textAppearance="@style/TextAppearance.Meli.BodyMuted"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileTopSection" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/profileActivityRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/meli_screen_padding"
        android:paddingTop="14dp"
        android:paddingEnd="@dimen/meli_screen_padding"
        android:paddingBottom="12dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileTopSection"
        tools:itemCount="3"
        tools:listitem="@layout/item_profile_ranking" />

</androidx.constraintlayout.widget.ConstraintLayout>
