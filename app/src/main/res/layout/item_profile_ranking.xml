<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/meli_card_spacing"
    android:background="@color/meli_surface"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_profile_avatar">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/rankingActorAvatarImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_black_24dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceMeliCircle" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/rankingActorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/meli_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rankingArtistsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/meli_text_muted"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/rankingListNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/meli_text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/rankingScoreText"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_list_score_circle"
            android:gravity="center"
            android:textColor="@color/meli_ink"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/rankingCoverImage"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="14dp"
        android:contentDescription="Album cover"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceMeliCard" />

    <TextView
        android:id="@+id/rankingNotesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Notes:"
        android:textColor="@color/meli_ink"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/rankingNotesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/meli_ink"
        android:textSize="16sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/rankingLikeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:drawableStart="@drawable/ic_feed_heart_outline"
            android:drawablePadding="8dp"
            android:paddingEnd="18dp"
            android:text="0"
            android:textColor="@color/meli_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rankingCommentButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:drawableStart="@drawable/ic_feed_comment_bubble"
            android:drawablePadding="8dp"
            android:text="0"
            android:textColor="@color/meli_ink"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
