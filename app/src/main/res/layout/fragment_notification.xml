<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/meli_paper"
    android:paddingStart="@dimen/meli_screen_padding"
    android:paddingTop="@dimen/meli_screen_padding"
    android:paddingEnd="@dimen/meli_screen_padding">

    <ImageButton
        android:id="@+id/button_close_notification"
        style="@style/Widget.Meli.IconButton"
        android:contentDescription="@string/cd_close_settings"
        android:src="@android:drawable/ic_media_previous"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/notificationTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notification_screen_title"
        android:textAppearance="@style/TextAppearance.Meli.ScreenTitle"
        app:layout_constraintBottom_toBottomOf="@id/button_close_notification"
        app:layout_constraintStart_toEndOf="@id/button_close_notification"
        app:layout_constraintTop_toTopOf="@id/button_close_notification" />

    <TextView
        android:id="@+id/notificationEmptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="No notifications yet."
        android:textAppearance="@style/TextAppearance.Meli.BodyMuted"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_close_notification" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notificationRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="18dp"
        android:paddingBottom="12dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_close_notification"
        tools:itemCount="4"
        tools:listitem="@layout/item_notification" />

</androidx.constraintlayout.widget.ConstraintLayout>
