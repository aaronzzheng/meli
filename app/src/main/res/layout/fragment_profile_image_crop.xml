<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/meli_surface"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adjust profile photo"
        android:textAppearance="@style/TextAppearance.Meli.SectionTitle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Pinch to zoom and drag to position."
        android:textAppearance="@style/TextAppearance.Meli.BodyMuted" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_marginTop="16dp">

        <com.example.meli.ui.profile.ProfileImageCropView
            android:id="@+id/profileImageCropView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.example.meli.ui.profile.ProfileImageCropOverlayView
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cropCancelButton"
            style="@style/Widget.Meli.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cropSaveButton"
            style="@style/Widget.Meli.PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Use Photo" />
    </LinearLayout>

</LinearLayout>
