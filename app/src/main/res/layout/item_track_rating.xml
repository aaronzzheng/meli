<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/meli_surface"
    android:orientation="vertical"
    android:paddingTop="18dp"
    android:paddingBottom="18dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/ratingTrackTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/ratingScoreText"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Meli.SectionTitle"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ratingArtistText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratingTrackTitle"
            android:layout_marginTop="6dp"
            android:layout_toStartOf="@id/ratingScoreText"
            android:textAppearance="@style/TextAppearance.Meli.BodyMuted"
            android:textColor="@color/meli_ink"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/ratingAlbumText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratingArtistText"
            android:layout_marginTop="2dp"
            android:layout_toStartOf="@id/ratingScoreText"
            android:textAppearance="@style/TextAppearance.Meli.BodyMuted"
            android:textColor="@color/meli_ink"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/ratingMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ratingAlbumText"
            android:layout_marginTop="28dp"
            android:layout_toStartOf="@id/ratingScoreText"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Meli.BodyMuted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/ratingScoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_list_score_circle"
            android:gravity="center"
            android:minWidth="64dp"
            android:minHeight="64dp"
            android:padding="12dp"
            android:textStyle="bold"
            android:textSize="22sp" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="@color/meli_line_soft" />
</LinearLayout>
