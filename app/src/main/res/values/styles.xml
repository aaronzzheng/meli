<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.Meli.ScreenTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/meli_ink</item>
    </style>

    <style name="TextAppearance.Meli.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/meli_ink</item>
    </style>

    <style name="TextAppearance.Meli.BodyMuted" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/meli_text_muted</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.Meli.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/meli_surface</item>
        <item name="strokeColor">@color/meli_line</item>
        <item name="strokeWidth">2dp</item>
        <item name="cardElevation">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Meli.Medium</item>
    </style>

    <style name="Widget.Meli.SearchCard" parent="Widget.Meli.Card">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Meli.Large</item>
    </style>

    <style name="Widget.Meli.DropdownCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/meli_surface</item>
        <item name="strokeColor">@color/meli_line_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">8dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Meli.Medium</item>
    </style>

    <style name="Widget.Meli.IconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:tint">@color/meli_ink</item>
    </style>

    <style name="Widget.Meli.OutlinedActionButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">40dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/meli_ink</item>
        <item name="strokeColor">@color/meli_line</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.Meli.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/meli_paper</item>
        <item name="backgroundTint">@color/meli_ink</item>
        <item name="cornerRadius">18dp</item>
    </style>

    <style name="Widget.Meli.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/meli_ink</item>
    </style>

    <style name="Widget.Meli.TextInputLayout.Outlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/meli_line</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/meli_text_muted</item>
        <item name="boxBackgroundColor">@color/meli_surface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Meli.Small</item>
    </style>

    <style name="Widget.Meli.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/meli_paper</item>
        <item name="itemIconTint">@color/meli_ink</item>
        <item name="itemTextColor">@color/meli_ink</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Meli.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Meli.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/meli_surface_subtle</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Meli.Medium</item>
    </style>

</resources>
