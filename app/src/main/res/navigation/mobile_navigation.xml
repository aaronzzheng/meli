<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_login">

    <fragment
        android:id="@+id/navigation_login"
        android:name="com.example.meli.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_navigation_login_to_navigation_home"
            app:destination="@id/navigation_home"
            app:popUpTo="@id/navigation_login"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.meli.ui.home.HomeFragment"
        android:label="meli"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/navigation_home_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_navigation_home_to_notificationFragment"
            app:destination="@id/notificationFragment" />
        <action
            android:id="@+id/action_navigation_home_to_userProfileFragment"
            app:destination="@id/userProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_list"
        android:name="com.example.meli.ui.list.ListFragment"
        android:label="Your List"
        tools:layout="@layout/fragment_list" />

    <fragment
        android:id="@+id/navigation_search"
        android:name="com.example.meli.ui.search.SearchFragment"
        android:label="meli"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_navigation_search_to_userProfileFragment"
            app:destination="@id/userProfileFragment" />
        <action
            android:id="@+id/action_navigation_search_to_recentTracksFragment"
            app:destination="@id/recentTracksFragment" />
        <action
            android:id="@+id/action_navigation_search_to_playlistsFragment"
            app:destination="@id/playlistsFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.meli.ui.profile.ProfileFragment"
        android:label="@string/title_profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_navigation_profile_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_navigation_profile_to_friendsFragment"
            app:destination="@id/friendsFragment" />
        <action
            android:id="@+id/action_navigation_profile_to_navigation_login"
            app:destination="@id/navigation_login"
            app:popUpTo="@id/mobile_navigation"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.meli.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <argument
            android:name="profileUid"
            app:argType="string" />
        <action
            android:id="@+id/action_userProfileFragment_to_friendsFragment"
            app:destination="@id/friendsFragment" />
    </fragment>
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.meli.ui.settings.SettingsFragment"
        android:label="@string/title_settings">
        <action
            android:id="@+id/action_settingsFragment_to_settingsDetailFragment"
            app:destination="@id/settingsDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.example.meli.ui.notification.NotificationFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notification" />

    <fragment
        android:id="@+id/friendsFragment"
        android:name="com.example.meli.ui.friends.FriendsFragment"
        android:label="Friends"
        tools:layout="@layout/fragment_friends">
        <action
            android:id="@+id/action_friendsFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountSettingsFragment"
        android:name="com.example.meli.ui.settings.AccountSettingsFragment"
        android:label="Account"
        tools:layout="@layout/fragment_account_settings">
        <action
            android:id="@+id/action_accountSettingsFragment_to_navigation_login"
            app:destination="@id/navigation_login"
            app:popUpTo="@id/mobile_navigation"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settingsDetailFragment"
        android:name="com.example.meli.ui.settings.SettingsDetailFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings_detail">
        <action
            android:id="@+id/action_settingsDetailFragment_to_accountSettingsFragment"
            app:destination="@id/accountSettingsFragment" />
        <action
            android:id="@+id/action_settingsDetailFragment_to_navigation_login"
            app:destination="@id/navigation_login"
            app:popUpTo="@id/mobile_navigation"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/recentTracksFragment"
        android:name="com.example.meli.ui.search.RecentTracksFragment"
        android:label="Recently Played"
        tools:layout="@layout/fragment_recent_tracks" />

    <fragment
        android:id="@+id/playlistsFragment"
        android:name="com.example.meli.ui.search.PlaylistsFragment"
        android:label="Playlists"
        tools:layout="@layout/fragment_playlists" />

    <fragment
        android:id="@+id/trackDetailFragment"
        android:name="com.example.meli.ui.search.TrackDetailFragment"
        android:label="Track"
        tools:layout="@layout/fragment_track_detail">
        <argument
            android:name="trackId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="trackName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="trackArtists"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="trackAlbum"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="trackImageUrl"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/playlistDetailFragment"
        android:name="com.example.meli.ui.search.PlaylistDetailFragment"
        android:label="Playlist"
        tools:layout="@layout/fragment_playlist_detail">
        <argument
            android:name="playlistId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistImageUrl"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistOwnerId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistOwner"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistDescription"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="playlistTrackCount"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>
</navigation>
