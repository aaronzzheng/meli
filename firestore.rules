rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFriendParticipant(uid, friendUid) {
      return isSignedIn() && (request.auth.uid == uid || request.auth.uid == friendUid);
    }

    // Signed-in users can discover basic profiles for search and social features.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);

      // Signed-in users can read friend edges for counts/social state.
      match /friends/{friendUid} {
        allow read: if isSignedIn();
        allow create: if isFriendParticipant(uid, friendUid);
        allow update, delete: if isFriendParticipant(uid, friendUid);
      }

      match /notifications/{notificationId} {
        // Owner can read all their notifications.
        // Actor can read notifications they created — needed when cleaning up on account delete.
        allow read: if isOwner(uid)
          || (isSignedIn() && resource.data.actorUid == request.auth.uid);
        allow update: if isOwner(uid)
          || (isSignedIn()
          && resource.data.type == "FRIEND_REQUEST"
          && resource.data.actorUid == request.auth.uid
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.type == "FRIEND_REQUEST");
        // Owner can delete any notification.
        // Actor can delete any notification they created (e.g. on account deletion).
        allow delete: if isOwner(uid)
          || (isSignedIn() && resource.data.actorUid == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      }

      // Ranking activity is visible to signed-in users so feeds can aggregate friend updates.
      match /rankingLists/{listId} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);

        match /entries/{entryId} {
          allow read: if isSignedIn();
          allow create, delete: if isOwner(uid);
          allow update: if isOwner(uid)
            || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeCount", "commentCount"]));

          match /likes/{likeUid} {
            allow read: if isSignedIn();
            allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
            allow update: if false;
          }

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
            allow update: if isOwner(uid)
              || (isSignedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeCount"]));
            allow delete: if false;

            match /likes/{likeUid} {
              allow read: if isSignedIn();
              allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
              allow update: if false;
            }
          }
        }
      }

      // Ratings are readable by any signed-in user so friends can see
      // each other's scores in the "What your friends ranked" section.
      match /ratings/{ratingId} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /notes/{noteId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    // Username lookup needs unauthenticated reads during sign-up.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /emails/{email} {
      allow get: if true;
      allow list: if false;
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
